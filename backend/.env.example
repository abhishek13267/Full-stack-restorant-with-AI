# =============================================
#   SAFFRON & SAGE — Environment Config EXAMPLE
#   Copy this file as '.env' and fill in your values
# =============================================

# Server
PORT=5001

# API Security (for dashboard access)
API_SECRET=your_super_secret_key_here
JWT_SECRET=super_secret_saffron_and_sage_key_2026

# Database
MONGODB_URI=mongodb+srv://your_user:your_pass@your_cluster.mongodb.net/saffron-sage?retryWrites=true&w=majority

# Database
DB_FILE=./database.sqlite

# PayPal (use 'sb' for sandbox, real Client ID for production)
PAYPAL_CLIENT_ID=sb
PAYPAL_CURRENCY=USD
