# =============================================
#   SAFFRON & SAGE — .gitignore
# =============================================

# Dependencies
node_modules/
backend/node_modules/

# Environment Variables (NEVER commit these)
.env
backend/.env

# Database file (contains real user data)
backend/database.sqlite

# Log files
backend/orders.log
backend/messages.log

# Vite build output
dist/
.vite/

# OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/
*.code-workspace

# Temporary files
*.tmp
*.log
